<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer padding with cream background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/vesta_bg" />
            <padding
                android:left="8dp"
                android:top="8dp"
                android:right="8dp"
                android:bottom="8dp" />
        </shape>
    </item>
    <!-- White rounded bar -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/vesta_surface" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="@color/vesta_border" />
        </shape>
    </item>
</layer-list>
